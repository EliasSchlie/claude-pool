{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Pool Protocol",
  "description": "Socket API contract. All requests and responses are newline-delimited JSON. Every request has a 'type' field. Responses echo back the 'id' field if provided. Sessions are always addressed by Claude UUID.",

  "$defs": {
    "claudeUUID": {
      "type": "string",
      "pattern": "^[a-f0-9-]+$",
      "description": "Claude Code session UUID"
    },

    "poolState": {
      "type": "object",
      "description": "Pool state: session list, config, metadata"
    },

    "healthReport": {
      "type": "object",
      "description": "Pool health: per-session status, counts, PID liveness"
    },

    "sessionInfo": {
      "type": "object",
      "properties": {
        "sessionId": { "$ref": "#/$defs/claudeUUID" },
        "status": { "enum": ["fresh", "idle", "processing", "dead", "error"] },
        "cwd": { "type": ["string", "null"] },
        "createdAt": { "type": "string" },
        "pid": { "type": ["integer", "null"] }
      }
    },

    "poolConfig": {
      "type": "object",
      "properties": {
        "flags": {
          "type": "string",
          "description": "Claude CLI flags for all sessions"
        },
        "size": { "type": "integer", "minimum": 0 }
      }
    }
  },

  "commands": {
    "ping": {
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "ping" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pong" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "pool-init": {
      "description": "Initialize a new pool. Reads flags from config.json (or uses --flags override). Default flags: --dangerously-skip-permissions.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-init" },
          "id": { "type": "integer" },
          "size": { "type": "integer", "minimum": 1, "default": 5 },
          "flags": {
            "type": "string",
            "description": "Override config flags for this init"
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "pool-resize": {
      "description": "Resize pool. New slots use flags from config.json.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-resize" },
          "id": { "type": "integer" },
          "size": { "type": "integer", "minimum": 0 }
        },
        "required": ["type", "size"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "pool-health": {
      "description": "Get pool health report",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-health" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "health" },
          "id": { "type": "integer" },
          "health": { "$ref": "#/$defs/healthReport" }
        },
        "required": ["type", "health"]
      }
    },

    "pool-read": {
      "description": "Read raw pool state",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-read" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "pool-destroy": {
      "description": "Kill all sessions and remove pool",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-destroy" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "pool-config": {
      "description": "Get or set pool configuration. Affects future spawns only.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-config" },
          "id": { "type": "integer" },
          "set": {
            "$ref": "#/$defs/poolConfig",
            "description": "Fields to update. Omit to read current config."
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "config" },
          "id": { "type": "integer" },
          "config": { "$ref": "#/$defs/poolConfig" }
        },
        "required": ["type", "config"]
      }
    },

    "pool-start": {
      "description": "Send a prompt to a fresh session. Automatically offloads LRU idle session if no fresh slots available.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-start" },
          "id": { "type": "integer" },
          "prompt": { "type": "string" }
        },
        "required": ["type", "prompt"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "started" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" }
        },
        "required": ["type", "sessionId"]
      }
    },

    "pool-resume": {
      "description": "Resume an offloaded/archived session. Claims a fresh slot, sends /resume. Session ID may change (new Claude UUID assigned).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-resume" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "resumed" },
          "id": { "type": "integer" },
          "sessionId": {
            "$ref": "#/$defs/claudeUUID",
            "description": "New session UUID (may differ from request)"
          }
        },
        "required": ["type", "sessionId"]
      }
    },

    "pool-followup": {
      "description": "Send a follow-up prompt to an idle session. Errors if session is busy (unless force=true). Auto-resumes if session is offloaded.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-followup" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" },
          "prompt": { "type": "string" },
          "force": { "type": "boolean", "default": false }
        },
        "required": ["type", "sessionId", "prompt"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "started" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" }
        },
        "required": ["type", "sessionId"]
      }
    },

    "pool-wait": {
      "description": "Long-poll until session becomes idle. If no sessionId, waits for any busy session.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-wait" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" },
          "timeout": {
            "type": "integer",
            "minimum": 0,
            "default": 300000,
            "description": "Timeout in ms"
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" },
          "buffer": { "type": "string" }
        },
        "required": ["type", "sessionId", "buffer"]
      }
    },

    "pool-capture": {
      "description": "Get terminal buffer content (works even while session is running).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-capture" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "buffer" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" },
          "buffer": { "type": "string" }
        },
        "required": ["type", "sessionId", "buffer"]
      }
    },

    "pool-result": {
      "description": "Get terminal buffer only if session is idle. Errors if still running.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" },
          "buffer": { "type": "string" }
        },
        "required": ["type", "sessionId", "buffer"]
      }
    },

    "pool-input": {
      "description": "Send raw keystrokes to a session's terminal.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-input" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" },
          "data": { "type": "string" }
        },
        "required": ["type", "sessionId", "data"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "pool-offload": {
      "description": "Manually offload a specific idle session (snapshot + /clear). Errors if session is busy.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-offload" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "get-sessions": {
      "description": "List all sessions (live + offloaded)",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "get-sessions" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "sessions" },
          "id": { "type": "integer" },
          "sessions": {
            "type": "array",
            "items": { "$ref": "#/$defs/sessionInfo" }
          }
        },
        "required": ["type", "sessions"]
      }
    },

    "archive-session": {
      "description": "Archive a session (offloads first if live)",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "archive-session" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "unarchive-session": {
      "description": "Move session from archived back to recent",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "unarchive-session" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "pin-session": {
      "description": "Prevent a session from being auto-offloaded by LRU eviction",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pin-session" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" },
          "duration": {
            "type": "integer",
            "minimum": 0,
            "default": 120,
            "description": "Pin duration in seconds"
          }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "unpin-session": {
      "description": "Allow a session to be auto-offloaded again",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "unpin-session" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "stop-session": {
      "description": "Interrupt a running session (sends Ctrl+C)",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "stop-session" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "attach": {
      "description": "Attach to a live session's terminal. Returns a socket path for raw PTY I/O. Pipe closes automatically if session is offloaded. Only works for live (in-slot) sessions.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "attach" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/claudeUUID" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "attached" },
          "id": { "type": "integer" },
          "socketPath": {
            "type": "string",
            "description": "Path to raw PTY pipe socket"
          }
        },
        "required": ["type", "socketPath"]
      }
    },

    "error": {
      "description": "Error response (returned for any failed command)",
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "error" },
          "id": { "type": "integer" },
          "error": { "type": "string" }
        },
        "required": ["type", "error"]
      }
    }
  }
}
