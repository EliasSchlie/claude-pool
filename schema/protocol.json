{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Pool Protocol",
  "description": "Socket API contract. Sessions addressed by pool-assigned internal IDs (short random strings). Newline-delimited JSON over Unix socket.",

  "$defs": {
    "sessionId": {
      "type": "string",
      "description": "Pool-assigned internal session ID (short random string, stable across lifecycle)"
    },

    "claudeUUID": {
      "type": "string",
      "pattern": "^[a-f0-9-]+$",
      "description": "Claude Code session UUID (discovered after spawn, null while queued)"
    },

    "sessionStatus": {
      "enum": [
        "queued",
        "idle",
        "typing",
        "processing",
        "offloaded",
        "dead",
        "error"
      ],
      "description": "API-visible session states. Internal states (fresh, starting) are not exposed."
    },

    "poolState": {
      "type": "object",
      "description": "Pool state: session list, queue, config, metadata"
    },

    "healthReport": {
      "type": "object",
      "description": "Pool health: per-session status, counts, PID liveness, queue depth"
    },

    "sessionInfo": {
      "type": "object",
      "properties": {
        "sessionId": { "$ref": "#/$defs/sessionId" },
        "claudeUUID": { "$ref": "#/$defs/claudeUUID" },
        "status": { "$ref": "#/$defs/sessionStatus" },
        "parentId": {
          "type": ["string", "null"],
          "description": "Internal ID of parent session, null if spawned externally"
        },
        "priority": {
          "type": "number",
          "default": 0,
          "description": "Eviction priority (lower = evicted first)"
        },
        "cwd": { "type": ["string", "null"] },
        "createdAt": { "type": "string" },
        "pid": { "type": ["integer", "null"] }
      }
    },

    "poolConfig": {
      "type": "object",
      "properties": {
        "flags": {
          "type": "string",
          "description": "Claude CLI flags for all sessions"
        },
        "size": { "type": "integer", "minimum": 0 }
      }
    }
  },

  "commands": {
    "ping": {
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "ping" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pong" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "pool-init": {
      "description": "Initialize a new pool. Size and flags from config.json.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-init" },
          "id": { "type": "integer" },
          "size": {
            "type": "integer",
            "minimum": 1,
            "description": "Override config size"
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "pool-resize": {
      "description": "Resize pool. New slots use flags from config.json.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-resize" },
          "id": { "type": "integer" },
          "size": { "type": "integer", "minimum": 0 }
        },
        "required": ["type", "size"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "pool-health": {
      "description": "Get pool health report (always shows full pool, ignores ownership)",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-health" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "health" },
          "id": { "type": "integer" },
          "health": { "$ref": "#/$defs/healthReport" }
        },
        "required": ["type", "health"]
      }
    },

    "pool-read": {
      "description": "Read raw pool state",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-read" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "pool-destroy": {
      "description": "Kill all sessions and remove pool. Updates pools.json registry.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-destroy" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "pool-config": {
      "description": "Get or set pool configuration (flags, size). Affects future spawns only.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-config" },
          "id": { "type": "integer" },
          "set": {
            "$ref": "#/$defs/poolConfig",
            "description": "Fields to update. Omit to read."
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "config" },
          "id": { "type": "integer" },
          "config": { "$ref": "#/$defs/poolConfig" }
        },
        "required": ["type", "config"]
      }
    },

    "pool-start": {
      "description": "Start a new session. Returns internal ID immediately (even if queued). Parent auto-detected from CLAUDE_POOL_SESSION_ID env var, or set via parentId.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-start" },
          "id": { "type": "integer" },
          "prompt": { "type": "string" },
          "parentId": {
            "$ref": "#/$defs/sessionId",
            "description": "Explicit parent. Auto-detected from env if omitted."
          },
          "priority": {
            "type": "number",
            "default": 0,
            "description": "Eviction priority for this session"
          }
        },
        "required": ["type", "prompt"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "started" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "status": {
            "$ref": "#/$defs/sessionStatus",
            "description": "'queued' if no slot, else first real state"
          }
        },
        "required": ["type", "sessionId", "status"]
      }
    },

    "pool-followup": {
      "description": "Send prompt to idle session. Auto-resumes offloaded sessions. Errors if busy (unless force=true).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-followup" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "prompt": { "type": "string" },
          "force": { "type": "boolean", "default": false }
        },
        "required": ["type", "sessionId", "prompt"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "started" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      }
    },

    "pool-wait": {
      "description": "Long-poll until session becomes idle. Works for queued sessions. If no sessionId, waits for any owned busy session.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-wait" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "timeout": {
            "type": "integer",
            "minimum": 0,
            "default": 300000,
            "description": "Timeout in ms"
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "buffer": { "type": "string" }
        },
        "required": ["type", "sessionId", "buffer"]
      }
    },

    "pool-capture": {
      "description": "Get terminal buffer (works while running). Errors if not in a slot (queued/offloaded).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-capture" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "buffer" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "buffer": { "type": "string" }
        },
        "required": ["type", "sessionId", "buffer"]
      }
    },

    "pool-result": {
      "description": "Get terminal buffer only if idle. Errors if running, queued, or offloaded.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "buffer": { "type": "string" }
        },
        "required": ["type", "sessionId", "buffer"]
      }
    },

    "pool-input": {
      "description": "Send raw keystrokes to a live session. Errors if not in a slot.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-input" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "data": { "type": "string" }
        },
        "required": ["type", "sessionId", "data"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "pool-offload": {
      "description": "Manually offload an idle session (snapshot + /clear). Errors if busy.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pool-offload" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "get-sessions": {
      "description": "List sessions. Default: only owned sessions (children + descendants). all=true for all pool sessions.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "get-sessions" },
          "id": { "type": "integer" },
          "all": { "type": "boolean", "default": false }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "sessions" },
          "id": { "type": "integer" },
          "sessions": {
            "type": "array",
            "items": { "$ref": "#/$defs/sessionInfo" }
          }
        },
        "required": ["type", "sessions"]
      }
    },

    "get-session": {
      "description": "Get full details for a single session (internal ID, Claude UUID, parent, priority, status).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "get-session" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "session" },
          "id": { "type": "integer" },
          "session": { "$ref": "#/$defs/sessionInfo" }
        },
        "required": ["type", "session"]
      }
    },

    "pin-session": {
      "description": "Prevent auto-offload. If offloaded, triggers priority load (jumps queue). If queued, bumps to front.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pin-session" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "duration": {
            "type": "integer",
            "minimum": 0,
            "default": 120,
            "description": "Seconds"
          }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "unpin-session": {
      "description": "Allow auto-offload again",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "unpin-session" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "stop-session": {
      "description": "Interrupt a running session (sends Ctrl+C). Transitions processing → idle.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "stop-session" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "set-priority": {
      "description": "Set session eviction priority. Lower = evicted first. Default 0. Does not affect queue order or processing speed.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "set-priority" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "priority": { "type": "number" }
        },
        "required": ["type", "sessionId", "priority"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "attach": {
      "description": "Attach to live session terminal. Returns socket path for raw PTY I/O. Pipe closes on offload/death. Errors if not live.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "attach" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "attached" },
          "id": { "type": "integer" },
          "socketPath": {
            "type": "string",
            "description": "Path to raw PTY pipe socket"
          }
        },
        "required": ["type", "socketPath"]
      }
    },

    "error": {
      "description": "Error response (returned for any failed command)",
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "error" },
          "id": { "type": "integer" },
          "error": { "type": "string" }
        },
        "required": ["type", "error"]
      }
    }
  }
}
