{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Pool Protocol",
  "description": "Socket API contract. Flat command naming. Sessions addressed by pool-assigned internal IDs. Newline-delimited JSON over Unix socket.",

  "$defs": {
    "sessionId": {
      "type": "string",
      "description": "Pool-assigned internal session ID (short random string, stable across lifecycle)"
    },

    "claudeUUID": {
      "type": "string",
      "pattern": "^[a-f0-9-]+$",
      "description": "Claude Code session UUID (discovered after spawn, null while queued)"
    },

    "sessionStatus": {
      "enum": [
        "queued",
        "idle",
        "typing",
        "processing",
        "offloaded",
        "dead",
        "error"
      ],
      "description": "API-visible session states. Internal states (fresh, starting) are not exposed."
    },

    "poolState": {
      "type": "object",
      "description": "Pool state: session list, queue, config, metadata"
    },

    "healthReport": {
      "type": "object",
      "description": "Pool health: per-session status, counts, PID liveness, queue depth"
    },

    "sessionInfo": {
      "type": "object",
      "properties": {
        "sessionId": { "$ref": "#/$defs/sessionId" },
        "claudeUUID": { "$ref": "#/$defs/claudeUUID" },
        "status": { "$ref": "#/$defs/sessionStatus" },
        "parentId": {
          "type": ["string", "null"],
          "description": "Internal ID of parent session"
        },
        "priority": {
          "type": "number",
          "default": 0,
          "description": "Eviction priority (lower = evicted first)"
        },
        "cwd": { "type": ["string", "null"] },
        "createdAt": { "type": "string" },
        "pid": { "type": ["integer", "null"] }
      }
    },

    "poolConfig": {
      "type": "object",
      "properties": {
        "flags": {
          "type": "string",
          "description": "Claude CLI flags for all sessions"
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "description": "Default pool size"
        }
      }
    }
  },

  "commands": {
    "ping": {
      "description": "Health check. Returns immediately.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "ping" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pong" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "init": {
      "description": "Initialize pool. Size optional (falls back to config). Flags from config.json.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "init" },
          "id": { "type": "integer" },
          "size": {
            "type": "integer",
            "minimum": 1,
            "description": "Slot count. Falls back to config.json if omitted."
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "resize": {
      "description": "Resize pool. New slots use config flags. Shrinking kills: queued first, then low-priority idle, then processing.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "resize" },
          "id": { "type": "integer" },
          "size": { "type": "integer", "minimum": 0 }
        },
        "required": ["type", "size"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "health": {
      "description": "Pool health report. Always shows full pool (ignores ownership).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "health" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "health" },
          "id": { "type": "integer" },
          "health": { "$ref": "#/$defs/healthReport" }
        },
        "required": ["type", "health"]
      }
    },

    "destroy": {
      "description": "Kill all sessions, remove pool directory, update registry. Daemon exits. Irreversible.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "destroy" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "config": {
      "description": "Read or update pool config. Changes affect future spawns only.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "config" },
          "id": { "type": "integer" },
          "set": {
            "$ref": "#/$defs/poolConfig",
            "description": "Fields to update. Omit to read."
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "config" },
          "id": { "type": "integer" },
          "config": { "$ref": "#/$defs/poolConfig" }
        },
        "required": ["type", "config"]
      }
    },

    "start": {
      "description": "Start new session. Returns internal ID immediately (even if queued).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "start" },
          "id": { "type": "integer" },
          "prompt": { "type": "string" },
          "parentId": {
            "$ref": "#/$defs/sessionId",
            "description": "Explicit parent. Auto-detected from env if omitted."
          },
          "priority": {
            "type": "number",
            "default": 0,
            "description": "Eviction priority"
          }
        },
        "required": ["type", "prompt"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "started" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "status": { "$ref": "#/$defs/sessionStatus" }
        },
        "required": ["type", "sessionId", "status"]
      }
    },

    "followup": {
      "description": "Send prompt to session. Auto-resumes if offloaded. Errors if busy (unless force).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "followup" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "prompt": { "type": "string" },
          "force": { "type": "boolean", "default": false }
        },
        "required": ["type", "sessionId", "prompt"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "started" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      }
    },

    "wait": {
      "description": "Long-poll until session idle. Works for queued sessions. No sessionId = any owned busy session.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "wait" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "timeout": {
            "type": "integer",
            "minimum": 0,
            "default": 300000,
            "description": "Timeout in ms"
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "buffer": { "type": "string" }
        },
        "required": ["type", "sessionId", "buffer"]
      }
    },

    "capture": {
      "description": "Get terminal buffer (any live state). Errors if queued/offloaded.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "capture" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "buffer" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "buffer": { "type": "string" }
        },
        "required": ["type", "sessionId", "buffer"]
      }
    },

    "result": {
      "description": "Get terminal buffer only if idle. Errors for any other state.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "buffer": { "type": "string" }
        },
        "required": ["type", "sessionId", "buffer"]
      }
    },

    "input": {
      "description": "Send raw bytes to session PTY. No timing dance. Errors if no terminal (queued/offloaded).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "input" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "data": { "type": "string" }
        },
        "required": ["type", "sessionId", "data"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "offload": {
      "description": "Manually offload idle session (snapshot + /clear + kill PTY). Errors if busy or pinned.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "offload" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "ls": {
      "description": "List sessions. Default: owned only. all=true for everything.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "ls" },
          "id": { "type": "integer" },
          "all": { "type": "boolean", "default": false }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "sessions" },
          "id": { "type": "integer" },
          "sessions": {
            "type": "array",
            "items": { "$ref": "#/$defs/sessionInfo" }
          }
        },
        "required": ["type", "sessions"]
      }
    },

    "info": {
      "description": "Full details for one session. Works for any state.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "info" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "session" },
          "id": { "type": "integer" },
          "session": { "$ref": "#/$defs/sessionInfo" }
        },
        "required": ["type", "session"]
      }
    },

    "pin": {
      "description": "Prevent auto-offload. Offloaded → priority load. Queued → bumps to front.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pin" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "duration": {
            "type": "integer",
            "minimum": 0,
            "default": 120,
            "description": "Seconds"
          }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "unpin": {
      "description": "Allow auto-offload again. No-op if not pinned.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "unpin" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "stop": {
      "description": "Send Ctrl+C to interrupt processing session. No-op if already idle.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "stop" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "set-priority": {
      "description": "Set eviction priority. Lower = evicted first. No effect on queue or processing.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "set-priority" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "priority": { "type": "number" }
        },
        "required": ["type", "sessionId", "priority"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "attach": {
      "description": "Raw PTY pipe for live session. Multiple clients can attach (broadcast). Pipe closes on offload/death.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "attach" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "attached" },
          "id": { "type": "integer" },
          "socketPath": {
            "type": "string",
            "description": "Temporary Unix socket for raw PTY I/O"
          }
        },
        "required": ["type", "socketPath"]
      }
    },

    "error": {
      "description": "Error response for any failed command",
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "error" },
          "id": { "type": "integer" },
          "error": { "type": "string" }
        },
        "required": ["type", "error"]
      }
    }
  }
}
