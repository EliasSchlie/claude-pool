{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Pool Protocol",
  "description": "Socket API contract. Flat command naming. Sessions addressed by pool-assigned internal IDs. Newline-delimited JSON over Unix socket.",

  "$defs": {
    "sessionId": {
      "type": "string",
      "description": "Pool-assigned internal session ID (short random string, stable across lifecycle)"
    },

    "claudeUUID": {
      "type": "string",
      "pattern": "^[a-f0-9-]+$",
      "description": "Claude Code session UUID (null until first spawn; retained when re-queued from offloaded). Use info command to look up."
    },

    "sessionStatus": {
      "enum": [
        "queued",
        "idle",
        "processing",
        "offloaded",
        "error",
        "archived"
      ],
      "description": "API-visible session states. Internal slot states (fresh, loading, live, error) are not exposed. Offloaded sessions can transition to queued via followup/pin."
    },

    "captureSource": {
      "enum": ["jsonl", "buffer"],
      "default": "jsonl",
      "description": "Where to read output. jsonl = Claude Code transcript (any state with UUID). buffer = raw terminal scrollback (live sessions only)."
    },

    "captureTurns": {
      "type": "integer",
      "minimum": 0,
      "default": 1,
      "description": "How many turns back. 1 = last turn, N = last N turns, 0 = entire history."
    },

    "captureDetail": {
      "enum": ["last", "assistant", "tools", "raw"],
      "default": "last",
      "description": "What to include per turn (JSONL only, ignored for buffer). last = user prompt + final assistant response, no tool calls. assistant = user prompt + all assistant text responses, no tool calls. tools = prompts + responses + tool calls/results, no metadata. raw = everything unfiltered."
    },

    "poolState": {
      "type": "object",
      "properties": {
        "size": {
          "type": "integer",
          "description": "Current slot count"
        },
        "sessions": {
          "type": "array",
          "items": { "$ref": "#/$defs/sessionInfo" },
          "description": "All sessions in the pool"
        },
        "queue": {
          "type": "array",
          "items": { "$ref": "#/$defs/sessionId" },
          "description": "Queued session IDs in FIFO order"
        },
        "config": { "$ref": "#/$defs/poolConfig" }
      },
      "required": ["size", "sessions", "queue", "config"],
      "description": "Pool state: slots, sessions, queue, config"
    },

    "healthReport": {
      "type": "object",
      "properties": {
        "size": {
          "type": "integer",
          "description": "Current slot count"
        },
        "counts": {
          "type": "object",
          "properties": {
            "queued": { "type": "integer" },
            "idle": { "type": "integer" },
            "processing": { "type": "integer" },
            "offloaded": { "type": "integer" },
            "error": { "type": "integer" },
            "archived": { "type": "integer" }
          },
          "description": "Session count per state"
        },
        "queueDepth": {
          "type": "integer",
          "description": "Number of queued requests"
        },
        "sessions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sessionId": { "$ref": "#/$defs/sessionId" },
              "status": { "$ref": "#/$defs/sessionStatus" },
              "pid": { "type": ["integer", "null"] },
              "pidAlive": { "type": "boolean" }
            },
            "required": ["sessionId", "status", "pidAlive"]
          },
          "description": "Per-session health: status and PID liveness"
        }
      },
      "required": ["size", "counts", "queueDepth", "sessions"],
      "description": "Pool health: counts per state, PID liveness, queue depth"
    },

    "sessionInfo": {
      "type": "object",
      "properties": {
        "sessionId": { "$ref": "#/$defs/sessionId" },
        "claudeUUID": { "$ref": "#/$defs/claudeUUID" },
        "status": { "$ref": "#/$defs/sessionStatus" },
        "parentId": {
          "type": ["string", "null"],
          "description": "Internal ID of parent session"
        },
        "priority": {
          "type": "number",
          "default": 0,
          "description": "Eviction priority (lower = evicted first, negative allowed)"
        },
        "cwd": {
          "type": ["string", "null"],
          "description": "Current working directory. Live sessions: detected via process inspection. Offloaded/error: last known from JSONL transcript."
        },
        "spawnCwd": {
          "type": ["string", "null"],
          "description": "Directory the session was originally spawned in (never changes)"
        },
        "createdAt": { "type": "string" },
        "pid": { "type": ["integer", "null"] },
        "pinned": {
          "type": "boolean",
          "description": "Whether the session is currently pinned (prevents LRU eviction)"
        },
        "pendingInput": {
          "type": "string",
          "description": "Un-submitted text in terminal buffer. Empty string if nothing typed. Only populated for loaded sessions. Changes reset LRU timestamp."
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/sessionInfo" },
          "description": "Direct child sessions (recursive). Populated by info and ls (with tree: true)."
        }
      },
      "required": ["sessionId", "status"]
    },

    "poolConfig": {
      "type": "object",
      "properties": {
        "flags": {
          "type": "string",
          "description": "Claude CLI flags for all sessions"
        },
        "size": {
          "type": "integer",
          "minimum": 1,
          "description": "Default pool size"
        }
      }
    }
  },

  "commands": {
    "ping": {
      "description": "Health check. Returns immediately.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "ping" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pong" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "init": {
      "description": "Initialize pool. Restores previously live sessions by default. Size optional (falls back to config).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "init" },
          "id": { "type": "integer" },
          "size": {
            "type": "integer",
            "minimum": 1,
            "description": "Slot count. Falls back to config.json if omitted."
          },
          "noRestore": {
            "type": "boolean",
            "default": false,
            "description": "Skip restoring previously live sessions. All slots get fresh pre-warmed sessions."
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "resize": {
      "description": "Resize pool. Shrinking enqueues kill-slot tokens at front. Processing sessions finish naturally. Pinned sessions never evicted. Queued requests stay queued.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "resize" },
          "id": { "type": "integer" },
          "size": { "type": "integer", "minimum": 1 }
        },
        "required": ["type", "size"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "health": {
      "description": "Pool health report. Always shows full pool (ignores ownership).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "health" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "health" },
          "id": { "type": "integer" },
          "health": { "$ref": "#/$defs/healthReport" }
        },
        "required": ["type", "health"]
      }
    },

    "destroy": {
      "description": "Kill all sessions, daemon exits. Pool directory and config persist. Re-init to restart.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "destroy" },
          "id": { "type": "integer" },
          "confirm": {
            "const": true,
            "description": "Must be true. Safety guard against accidental destruction."
          }
        },
        "required": ["type", "confirm"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "config": {
      "description": "Read or update pool config. Changes affect future spawns only.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "config" },
          "id": { "type": "integer" },
          "set": {
            "$ref": "#/$defs/poolConfig",
            "description": "Fields to update. Omit to read."
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "config" },
          "id": { "type": "integer" },
          "config": { "$ref": "#/$defs/poolConfig" }
        },
        "required": ["type", "config"]
      }
    },

    "start": {
      "description": "Start new session with prompt. Returns internal ID immediately (even if queued).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "start" },
          "id": { "type": "integer" },
          "prompt": { "type": "string" },
          "parentId": {
            "$ref": "#/$defs/sessionId",
            "description": "Explicit parent. Auto-detected from env if omitted."
          }
        },
        "required": ["type", "prompt"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "started" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "status": { "$ref": "#/$defs/sessionStatus" }
        },
        "required": ["type", "sessionId", "status"]
      }
    },

    "followup": {
      "description": "Send prompt to session. Auto-resumes if offloaded (queues for loading). Errors if queued/processing unless force. Errors if error unless force (resets retry counter). Errors if archived.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "followup" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "prompt": { "type": "string" },
          "force": { "type": "boolean", "default": false }
        },
        "required": ["type", "sessionId", "prompt"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "started" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "status": { "$ref": "#/$defs/sessionStatus" }
        },
        "required": ["type", "sessionId", "status"]
      }
    },

    "wait": {
      "description": "Long-poll until session idle. Works for queued sessions. No sessionId = any owned busy session.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "wait" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "timeout": {
            "type": "integer",
            "minimum": 0,
            "default": 300000,
            "description": "Timeout in ms"
          },
          "source": { "$ref": "#/$defs/captureSource" },
          "turns": { "$ref": "#/$defs/captureTurns" },
          "detail": { "$ref": "#/$defs/captureDetail" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "content": { "type": "string" }
        },
        "required": ["type", "sessionId", "content"]
      }
    },

    "capture": {
      "description": "Get session output. JSONL source works for any state with UUID. Buffer source requires live terminal.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "capture" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "source": { "$ref": "#/$defs/captureSource" },
          "turns": { "$ref": "#/$defs/captureTurns" },
          "detail": { "$ref": "#/$defs/captureDetail" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "content": { "type": "string" }
        },
        "required": ["type", "sessionId", "content"]
      }
    },

    "input": {
      "description": "Send raw bytes to session PTY. No timing dance. Errors if no live terminal (queued/offloaded/error/archived).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "input" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "data": { "type": "string" }
        },
        "required": ["type", "sessionId", "data"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "offload": {
      "description": "Manually offload idle session. Frees slot, saves metadata. Errors if busy. Unpins if pinned.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "offload" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "ls": {
      "description": "List sessions. Default: owned direct children (no archived). tree/all/archived flags available.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "ls" },
          "id": { "type": "integer" },
          "all": { "type": "boolean", "default": false },
          "tree": { "type": "boolean", "default": false },
          "archived": { "type": "boolean", "default": false }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "sessions" },
          "id": { "type": "integer" },
          "sessions": {
            "type": "array",
            "items": { "$ref": "#/$defs/sessionInfo" }
          }
        },
        "required": ["type", "sessions"]
      }
    },

    "info": {
      "description": "Full details for one session including recursive children and Claude UUID. Works for any state.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "info" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "session" },
          "id": { "type": "integer" },
          "session": { "$ref": "#/$defs/sessionInfo" }
        },
        "required": ["type", "session"]
      }
    },

    "pin": {
      "description": "Prevent auto-offload. No sessionId = allocate fresh session. Offloaded → queued for priority load. Queued → front of queue.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pin" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "parentId": {
            "$ref": "#/$defs/sessionId",
            "description": "Only used when no sessionId (fresh session mode). Auto-detected from env if omitted."
          },
          "duration": {
            "type": "integer",
            "minimum": 0,
            "default": 120,
            "description": "Seconds"
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "status": { "$ref": "#/$defs/sessionStatus" }
        },
        "required": ["type", "sessionId", "status"]
      }
    },

    "unpin": {
      "description": "Allow auto-offload again. No-op if not pinned.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "unpin" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "stop": {
      "description": "Interrupt processing (Ctrl+C) or cancel queued request. Synchronous: session is idle when ok returns. No-op if idle.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "stop" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "archive": {
      "description": "Archive session (mark as done). Stops active sessions first. Errors if unarchived children unless recursive. Auto-cleaned after 30 days.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "archive" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "recursive": {
            "type": "boolean",
            "default": false,
            "description": "Archive all descendants depth-first"
          }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "unarchive": {
      "description": "Restore archived session to offloaded state.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "unarchive" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "set-priority": {
      "description": "Set eviction priority. Lower = evicted first. Negative allowed. No effect on queue or processing.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "set-priority" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "priority": { "type": "number" }
        },
        "required": ["type", "sessionId", "priority"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "attach": {
      "description": "Raw PTY pipe for live session. Multiple clients can attach (broadcast). Pipe closes on offload/death.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "attach" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "attached" },
          "id": { "type": "integer" },
          "socketPath": {
            "type": "string",
            "description": "Temporary Unix socket for raw PTY I/O"
          }
        },
        "required": ["type", "socketPath"]
      }
    },

    "subscribe": {
      "description": "Open persistent event stream with optional filters. Sending subscribe again on the same connection replaces filters (no reconnect needed). Multiple connections can subscribe independently.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "subscribe" },
          "id": { "type": "integer" },
          "sessions": {
            "type": "array",
            "items": { "$ref": "#/$defs/sessionId" },
            "description": "Only events for these sessions. Omit = all."
          },
          "events": {
            "type": "array",
            "items": {
              "enum": [
                "status",
                "created",
                "updated",
                "archived",
                "unarchived",
                "pool"
              ]
            },
            "description": "Only these event types. Omit = all."
          },
          "statuses": {
            "type": "array",
            "items": { "$ref": "#/$defs/sessionStatus" },
            "description": "Only status events transitioning TO these states. Omit = all."
          },
          "fields": {
            "type": "array",
            "items": {
              "enum": ["cwd", "priority", "pinned", "pendingInput"]
            },
            "description": "Only updated events for these fields. Omit = all fields."
          }
        },
        "required": ["type"]
      },
      "events": {
        "type": "object",
        "properties": {
          "type": { "const": "event" },
          "event": {
            "enum": [
              "status",
              "created",
              "updated",
              "archived",
              "unarchived",
              "pool"
            ],
            "description": "Event type"
          },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "status": { "$ref": "#/$defs/sessionStatus" },
          "prevStatus": { "$ref": "#/$defs/sessionStatus" },
          "parentId": { "$ref": "#/$defs/sessionId" },
          "changes": {
            "type": "object",
            "description": "Changed fields and their new values (updated events only)"
          },
          "action": {
            "type": "string",
            "description": "Pool-level action (init, resize, destroy)"
          }
        },
        "required": ["type", "event"]
      }
    },

    "error": {
      "description": "Error response for any failed command",
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "error" },
          "id": { "type": "integer" },
          "error": { "type": "string" }
        },
        "required": ["type", "error"]
      }
    }
  }
}
