{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Pool Protocol",
  "description": "Socket API contract. Flat command naming. Sessions addressed by pool-assigned internal IDs. Newline-delimited JSON over Unix socket.",

  "$defs": {
    "sessionId": {
      "type": "string",
      "description": "Pool-assigned internal session ID (short random string, stable across lifecycle)"
    },

    "claudeUUID": {
      "type": "string",
      "pattern": "^[a-f0-9-]+$",
      "description": "Claude Code session UUID (discovered after spawn, null while queued). Use info command to look up."
    },

    "sessionStatus": {
      "enum": [
        "queued",
        "idle",
        "typing",
        "processing",
        "offloaded",
        "dead",
        "error",
        "archived"
      ],
      "description": "API-visible session states. Internal states (fresh, starting) are not exposed. Offloaded/dead/error sessions can transition to queued via followup/pin."
    },

    "outputFormat": {
      "enum": [
        "jsonl-last",
        "jsonl-short",
        "jsonl-long",
        "jsonl-full",
        "buffer-last",
        "buffer-full"
      ],
      "default": "jsonl-short",
      "description": "Output format. JSONL formats read from Claude Code transcripts (work for any state with UUID). Buffer formats require live terminal."
    },

    "poolState": {
      "type": "object",
      "description": "Pool state: session list, queue, config, metadata"
    },

    "healthReport": {
      "type": "object",
      "description": "Pool health: per-session status, counts, PID liveness, queue depth"
    },

    "sessionInfo": {
      "type": "object",
      "properties": {
        "sessionId": { "$ref": "#/$defs/sessionId" },
        "claudeUUID": { "$ref": "#/$defs/claudeUUID" },
        "status": { "$ref": "#/$defs/sessionStatus" },
        "parentId": {
          "type": ["string", "null"],
          "description": "Internal ID of parent session"
        },
        "priority": {
          "type": "number",
          "default": 0,
          "description": "Eviction priority (lower = evicted first, negative allowed)"
        },
        "cwd": { "type": ["string", "null"] },
        "createdAt": { "type": "string" },
        "pid": { "type": ["integer", "null"] },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/sessionInfo" },
          "description": "Direct child sessions (recursive). Populated by info and ls (with tree: true)."
        }
      }
    },

    "poolConfig": {
      "type": "object",
      "properties": {
        "flags": {
          "type": "string",
          "description": "Claude CLI flags for all sessions"
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "description": "Default pool size"
        }
      }
    }
  },

  "commands": {
    "ping": {
      "description": "Health check. Returns immediately.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "ping" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pong" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "init": {
      "description": "Initialize pool. Size optional (falls back to config). Flags from config.json.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "init" },
          "id": { "type": "integer" },
          "size": {
            "type": "integer",
            "minimum": 1,
            "description": "Slot count. Falls back to config.json if omitted."
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "resize": {
      "description": "Resize pool. Shrinking offloads idle (low priority first), then kills processing. Queued requests stay queued.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "resize" },
          "id": { "type": "integer" },
          "size": { "type": "integer", "minimum": 0 }
        },
        "required": ["type", "size"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "pool" },
          "id": { "type": "integer" },
          "pool": { "$ref": "#/$defs/poolState" }
        },
        "required": ["type", "pool"]
      }
    },

    "health": {
      "description": "Pool health report. Always shows full pool (ignores ownership).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "health" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "health" },
          "id": { "type": "integer" },
          "health": { "$ref": "#/$defs/healthReport" }
        },
        "required": ["type", "health"]
      }
    },

    "destroy": {
      "description": "Kill all sessions, daemon exits. Pool directory and config persist. Re-init to restart.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "destroy" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "config": {
      "description": "Read or update pool config. Changes affect future spawns only.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "config" },
          "id": { "type": "integer" },
          "set": {
            "$ref": "#/$defs/poolConfig",
            "description": "Fields to update. Omit to read."
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "config" },
          "id": { "type": "integer" },
          "config": { "$ref": "#/$defs/poolConfig" }
        },
        "required": ["type", "config"]
      }
    },

    "start": {
      "description": "Start new session with prompt. Returns internal ID immediately (even if queued).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "start" },
          "id": { "type": "integer" },
          "prompt": { "type": "string" },
          "parentId": {
            "$ref": "#/$defs/sessionId",
            "description": "Explicit parent. Auto-detected from env if omitted."
          }
        },
        "required": ["type", "prompt"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "started" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "status": { "$ref": "#/$defs/sessionStatus" }
        },
        "required": ["type", "sessionId", "status"]
      }
    },

    "followup": {
      "description": "Send prompt to session. Auto-resumes if offloaded/dead/error (queues for loading). Errors if queued/processing unless force. Errors if archived.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "followup" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "prompt": { "type": "string" },
          "force": { "type": "boolean", "default": false }
        },
        "required": ["type", "sessionId", "prompt"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "started" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      }
    },

    "wait": {
      "description": "Long-poll until session idle. Works for queued sessions. No sessionId = any owned busy session.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "wait" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "timeout": {
            "type": "integer",
            "minimum": 0,
            "default": 300000,
            "description": "Timeout in ms"
          },
          "format": { "$ref": "#/$defs/outputFormat" }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "content": { "type": "string" }
        },
        "required": ["type", "sessionId", "content"]
      }
    },

    "capture": {
      "description": "Get session output. JSONL formats work for any state with UUID. Buffer formats require live terminal.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "capture" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "format": { "$ref": "#/$defs/outputFormat" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "buffer" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "content": { "type": "string" }
        },
        "required": ["type", "sessionId", "content"]
      }
    },

    "result": {
      "description": "Get session output only if complete (idle/offloaded/archived). JSONL or buffer depending on format.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "format": { "$ref": "#/$defs/outputFormat" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "result" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "content": { "type": "string" }
        },
        "required": ["type", "sessionId", "content"]
      }
    },

    "input": {
      "description": "Send raw bytes to session PTY. No timing dance. Errors if no terminal (queued/offloaded).",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "input" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "data": { "type": "string" }
        },
        "required": ["type", "sessionId", "data"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "offload": {
      "description": "Manually offload idle session (save meta + /clear + kill PTY). No buffer snapshot. Errors if busy or pinned.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "offload" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "ls": {
      "description": "List sessions. Default: owned direct children (no archived). tree/all/archived flags available.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "ls" },
          "id": { "type": "integer" },
          "all": { "type": "boolean", "default": false },
          "tree": { "type": "boolean", "default": false },
          "archived": { "type": "boolean", "default": false }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "sessions" },
          "id": { "type": "integer" },
          "sessions": {
            "type": "array",
            "items": { "$ref": "#/$defs/sessionInfo" }
          }
        },
        "required": ["type", "sessions"]
      }
    },

    "info": {
      "description": "Full details for one session including recursive children and Claude UUID. Works for any state.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "info" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "session" },
          "id": { "type": "integer" },
          "session": { "$ref": "#/$defs/sessionInfo" }
        },
        "required": ["type", "session"]
      }
    },

    "pin": {
      "description": "Prevent auto-offload. No sessionId = allocate fresh session. Offloaded/dead → queued for priority load. Queued → front of queue.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "pin" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "parentId": {
            "$ref": "#/$defs/sessionId",
            "description": "Only used when no sessionId (fresh session mode). Auto-detected from env if omitted."
          },
          "duration": {
            "type": "integer",
            "minimum": 0,
            "default": 120,
            "description": "Seconds"
          }
        },
        "required": ["type"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "status": { "$ref": "#/$defs/sessionStatus" }
        },
        "required": ["type", "sessionId", "status"]
      }
    },

    "unpin": {
      "description": "Allow auto-offload again. No-op if not pinned.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "unpin" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "stop": {
      "description": "Interrupt processing (Ctrl+C) or cancel queued request. No-op if idle.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "stop" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "archive": {
      "description": "Archive session (mark as done). Stops active sessions first. Errors if unarchived children unless recursive. Auto-cleaned after 30 days.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "archive" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "recursive": {
            "type": "boolean",
            "default": false,
            "description": "Archive all descendants depth-first"
          }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "unarchive": {
      "description": "Restore archived session to offloaded state.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "unarchive" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "set-priority": {
      "description": "Set eviction priority. Lower = evicted first. Negative allowed. No effect on queue or processing.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "set-priority" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "priority": { "type": "number" }
        },
        "required": ["type", "sessionId", "priority"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "ok" },
          "id": { "type": "integer" }
        },
        "required": ["type"]
      }
    },

    "attach": {
      "description": "Raw PTY pipe for live session. Multiple clients can attach (broadcast). Pipe closes on offload/death.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "attach" },
          "id": { "type": "integer" },
          "sessionId": { "$ref": "#/$defs/sessionId" }
        },
        "required": ["type", "sessionId"]
      },
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "attached" },
          "id": { "type": "integer" },
          "socketPath": {
            "type": "string",
            "description": "Temporary Unix socket for raw PTY I/O"
          }
        },
        "required": ["type", "socketPath"]
      }
    },

    "subscribe": {
      "description": "Open persistent event stream with optional filters. Daemon pushes status changes, created, archived, pool events.",
      "request": {
        "type": "object",
        "properties": {
          "type": { "const": "subscribe" },
          "id": { "type": "integer" },
          "sessions": {
            "type": "array",
            "items": { "$ref": "#/$defs/sessionId" },
            "description": "Only events for these sessions. Omit = all."
          },
          "events": {
            "type": "array",
            "items": {
              "enum": ["status", "created", "archived", "unarchived", "pool"]
            },
            "description": "Only these event types. Omit = all."
          },
          "statuses": {
            "type": "array",
            "items": { "$ref": "#/$defs/sessionStatus" },
            "description": "Only status events transitioning TO these states. Omit = all."
          }
        },
        "required": ["type"]
      },
      "events": {
        "type": "object",
        "properties": {
          "type": { "const": "event" },
          "event": {
            "enum": ["status", "created", "archived", "unarchived", "pool"],
            "description": "Event type"
          },
          "sessionId": { "$ref": "#/$defs/sessionId" },
          "status": { "$ref": "#/$defs/sessionStatus" },
          "prevStatus": { "$ref": "#/$defs/sessionStatus" },
          "parentId": { "$ref": "#/$defs/sessionId" },
          "action": {
            "type": "string",
            "description": "Pool-level action (init, resize, destroy)"
          }
        },
        "required": ["type", "event"]
      }
    },

    "error": {
      "description": "Error response for any failed command",
      "response": {
        "type": "object",
        "properties": {
          "type": { "const": "error" },
          "id": { "type": "integer" },
          "error": { "type": "string" }
        },
        "required": ["type", "error"]
      }
    }
  }
}
